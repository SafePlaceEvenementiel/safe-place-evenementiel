AuthType Basic
AuthName "Safe Place Événementiel — Accès Prévisualisation"
AuthUserFile /homepages/votre-chemin/.htpasswd
Require valid-user

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript image/svg+xml
</IfModule>

# Cache navigateur
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css   "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Redirection www → sans www (à activer une fois le domaine pointé)
# RewriteEngine On
# RewriteCond %{HTTP_HOST} ^www\.safeplaceevenementiel\.fr [NC]
# RewriteRule ^ https://safeplaceevenementiel.fr%{REQUEST_URI} [L,R=301]
